# 1. Ignore ALL Python files in the root folder and loose directories by default
*.py

# 2. Allow/Track all python files specifically inside our live strategy package
!strategy/**/*.py

# 3. Ignore all research data, spreadsheets, and optimization files
*.xlsx
*.csv
*.pkl
*.docx
*.pdf
bars/
backtesting/
/backtesting
poetry.lock
pyproject.toml
# logs
local_data/
# data and config files
*.json
strategy/*.json
strategy/tangent/*.json
strategy/tangent/*.csv

# 4. Critical security boundary for cloud deployment
.env
*.env
strategy/.env
strategy/*.env

# 5. Local database and cache persistence
db.sqlite
data/
__pycache__/
*.pyc